@model ReceitasApp.Models.Receita

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Receita</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TempoPreparacao)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TempoPreparacao)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NumeroPessoas)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NumeroPessoas)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Dificuldade)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Dificuldade)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Categoria)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Categoria)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Preparacao)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Preparacao)
        </dd>
    </dl>
    <hr />
<h4>Ingredientes</h4>

@if (Model.Ingredientes != null && Model.Ingredientes.Any())
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Ingrediente</th>
                <th>Quantidade</th>
                <th>Medida</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Ingredientes)
            {
                <tr>
                    <td>@item.Ingrediente?.Nome</td>
                    <td>@item.Quantidade</td>
                    <td>@item.Medida</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Nenhum ingrediente cadastrado.</p>
}
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
